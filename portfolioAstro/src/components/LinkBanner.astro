---
interface Props {
  href: string;
  src: string;
  alt: string;
  label: string;
}

const { href, src, alt, label } = Astro.props;
---

<a href={href} target="_blank" rel="noopener noreferrer" class="banner-link">
  <img src={src} alt={alt} />
  <span>{label}</span>
</a>

<style>
  .banner-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 1px solid rgba(0, 0, 0, 0.03);
  }
  .banner-link:focus {
    outline: 2px solid #0066cc;
    outline-offset: 2px;
  }
  .banner-link:focus:not(:focus-visible) {
    outline: none;
  }
  .banner-link:focus-visible {
    outline: 2px solid #0066cc;
    outline-offset: 2px;
  }
  .banner-link:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }
  .banner-link img {
    height: 32px;
    width: auto;
    padding-right: 16px;
  }
</style>
