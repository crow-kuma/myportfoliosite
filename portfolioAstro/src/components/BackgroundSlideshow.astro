---
interface Props {
  artworkImageUrl?: string[];
  totalDuration?: number;
  durationPerSlide?: number;
}

const {
  artworkImageUrl = [],
  totalDuration = 10,
  durationPerSlide = 5,
} = Astro.props as Props;
---

<div class="background-slideshow">
  {
    artworkImageUrl &&
      artworkImageUrl.map((img: string, index: number) => (
        <div
          class={`slide slide${index + 1}`}
          style={`
            background-image: url('${img}');
            animation: fade ${totalDuration}s ${index * durationPerSlide}s infinite;
          `}
        />
      ))
  }
  <div class="background-overlay"></div>
</div>

<style>
  .background-slideshow {
    position: fixed;
    top: 0;
    left: 0;
    overflow: hidden;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    display: flex;
  }

  .background-slideshow::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2; /* .slideより上、.contentより下に調整 */
    background-image:
      radial-gradient(circle, rgba(255, 255, 255, 0.3) 1px, transparent 1px),
      radial-gradient(circle, rgba(255, 255, 255, 0.3) 1px, transparent 1px);
    background-position:
      0 0,
      2.5px 5px;
    background-size: 5px 10px;
  }
  .slide {
    position: absolute;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0;
    z-index: 1;
  }

  @keyframes fade {
    0% {
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    45% {
      opacity: 1;
    }
    55% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  @media (prefers-color-scheme: dark) {
    .background-slideshow .slide {
      filter: invert(1) hue-rotate(180deg);
    }
  }
</style>
