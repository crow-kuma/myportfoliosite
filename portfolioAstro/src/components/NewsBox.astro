---
import type { SanityDocument } from "@sanity/client";
import { sanityClient } from "sanity:client";

const NEWS_QUERY = `*[_type == "news" && public == true] | order(date desc)`;

const news = await sanityClient.fetch<SanityDocument[]>(NEWS_QUERY);
---

<div class="news-section">
  <div class="glb-tab-header">
    <h3 class="glb-u-bg-yellow">News</h3>
  </div>
  <ul>
    {
      news.map((item) => (
        <li>
          <p class="date">{item.date}</p>
          <p class="article">{item.article}</p>
          <a
            class="url"
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
          >
            {item.url}
          </a>
        </li>
      ))
    }
  </ul>

  <style is:global>
    .news-section {
      width: calc(100vw - 32px);
      max-width: calc(100vw - 32px);
      padding-bottom: 16px;
      box-sizing: border-box;
      border-radius: 8px;
    }
    .news-section > ul {
      background-color: rgba(255, 255, 255, 0.9);
      border: solid 2px #000;
      padding: 0;
    }
    .news-section > ul > li {
      margin: 0 16px;
      padding: 16px 0;
      border-bottom: solid 1px #ccc;
    }
    .news-section > ul > li:last-child {
      border-bottom: none;
    }
    .date {
      font-size: 0.8rem;
    }
    .article {
      white-space: pre-wrap;
    }
    .url {
      text-decoration: underline dotted;
      overflow-wrap: break-word;
      word-break: break-all;
    }
  </style>
</div>
