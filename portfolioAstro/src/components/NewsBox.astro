---
import type { SanityDocument } from "@sanity/client";
import { sanityClient } from "sanity:client";

const NEWS_QUERY = `*[_type == "news" && public == true] | order(date desc)`;

const news = await sanityClient.fetch<SanityDocument[]>(NEWS_QUERY);
---

<div class="news-box">
  <div class="title-tab">
    <h3>News</h3>
  </div>
  <ul>
    {
      news.map((item) => (
        <li>
          <p class="date">{item.date}</p>
          <p class="article">{item.article}</p>
          <a
            class="url"
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
          >
            {item.url}
          </a>
        </li>
      ))
    }
  </ul>

  <style is:global>
    .news-box {
      width: calc(100vw - 32px);
      max-width: calc(100vw - 32px);
      padding-bottom: 16px;
      box-sizing: border-box;
      border-radius: 8px;
    }

    .news-box > ul {
      background-color: rgba(255, 255, 255, 0.9);
      border: solid 2px #000;
      margin: 0 16px;
      padding: 0;
    }
    .news-box > ul > li {
      margin: 0 16px;
      padding: 16px 0;
      border-bottom: solid 1px #ccc;
    }
    .news-box > ul > li:last-child {
      border-bottom: none;
    }

    .title-tab {
      margin-left: 20px;
    }

    .title-tab > h3 {
      display: inline-block;
      background-color: #fdd835;
      padding: 2px 16px;
      border-top-left-radius: 8px;
      border-top-right-radius: 8px;
      font-size: 1.6rem;
      margin-bottom: 0;
    }

    .date {
      font-size: 0.8rem;
    }
    .article {
      white-space: pre-wrap;
    }
    .url {
      text-decoration: underline dotted;
    }
  </style>
</div>
