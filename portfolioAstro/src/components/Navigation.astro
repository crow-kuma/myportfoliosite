---
const menuItems = [
  { href: "/about", label: "About Crow", tooltip: "熊野クロウについて" },
  { href: "/works", label: "Works", tooltip: "作品・お仕事情報" },
  { href: "/contact", label: "Contact", tooltip: "SNS・ご連絡情報" },
  {
    href: "/playground",
    label: "Playground",
    tooltip: "お楽しみアプリ・配布物",
  },
];
---

<nav class="navigation glb-u-flex-center">
  <div class="site-branding">
    <h1 class="glb-title-font">
      <a href="/">Kumano Crow</a>
    </h1>
  </div>
  <ul class="menu glb-u-flex-center">
    {
      menuItems.map((item) => (
        <li>
          <a class="glb-u-flex-column" href={item.href} data-tooltip={item.tooltip}>
            {item.label}
            <div class="mobile-sublabel">{item.tooltip}</div>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .navigation {
    position: relative;
    padding: 8px 0 0;
    justify-content: space-between;
    box-shadow: 0 1px 5px rgb(0 0 0 / 20%);
    background-color: rgb(255 255 255 / 85%);
    z-index: 10;
    flex-wrap: wrap;
  }

  @media (width >= 768px) {
    .navigation {
      padding: 0;
      flex-wrap: nowrap;
    }
  }

  .site-branding {
    font-size: 1.5rem;
    font-weight: bold;
    padding-left: 10px;
    flex-shrink: 0;
  }

  @media (width >= 768px) {
    .site-branding {
      font-size: 1.8rem;
    }
  }

  .site-branding h1 {
    padding-left: 10px;
    line-height: 1.2em;
    font-size: 1.2em !important;
  }

  @media (width >= 768px) {
    .site-branding h1 {
      line-height: 1em;
      font-size: 1.5em !important;
    }
  }

  .menu {
    align-items: center;
    width: 100%;
    margin-top: 8px;
    border-top: 1px solid #eee;
  }

  @media (width >= 768px) {
    .menu {
      width: auto;
      margin-top: 0;
      border-top: none;
    }
  }

  .menu li {
    flex: 1;
    display: flex;
    position: relative;
  }

  @media (width >= 768px) {
    .menu li {
      width: 160px;
      flex: none;
    }
  }

  .menu li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 1.5rem;
    width: 1px;
    background-color: #ccc;
  }

  .menu a {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    line-height: 2rem;
    font-size: 0.9rem;
  }

  @media (width >= 768px) {
    .menu a {
      line-height: 3rem;
      font-size: 1rem;
    }
  }

  /* Tooltips - Only show on screens with hover capability and larger width */
  @media (hover: hover) and (width >= 768px) {
    .menu a::after {
      content: attr(data-tooltip);
      position: absolute;
      top: 129%;
      left: 50%;
      transform: translateX(-50%);
      white-space: nowrap;
      background-color: rgb(0 0 0 / 80%);
      color: #fff;
      font-size: 0.75rem;
      padding: 4px 8px;
      border-radius: 4px;
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease-in-out;
      z-index: 20;
    }

    .menu a::before {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border-width: 6px;
      border-style: solid;
      border-color: transparent transparent rgb(0 0 0 / 80%);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease-in-out;
      z-index: 20;
    }

    .menu a:hover::after,
    .menu a:hover::before {
      opacity: 1;
      visibility: visible;
    }
  }

  /* label for mobile - this shows tooltip text in mobile */
  .mobile-sublabel {
    display: block;
    font-size: 0.5rem;
    line-height: 0.8em;
    padding-bottom: 0.3rem;
  }

  @media (width >= 768px) {
    .mobile-sublabel {
      display: none;
    }
  }
</style>
