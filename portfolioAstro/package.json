{
  "name": "portfolioAstro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "lint:css": "stylelint \"src/**/*.css\" \"src/**/*.scss\" \"**/*.astro\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" \"src/**/*.scss\" \"**/*.astro\" --fix"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/react": "^6.0.0",
    "@sanity/astro": "^3.0.1",
    "@sanity/client": "7.23.0",
    "@sanity/vision": "^5.31.1",
    "astro": "^7.0.3",
    "astro-portabletext": "0.13.0",
    "lightgallery": "^2.9.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "react-is": "^19.2.7",
    "sanity": "^5.14.1",
    "styled-components": "^6.4.3",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "postcss-html": "^1.8.1",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.14.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.2.0",
    "vite": "^8.1.0"
  },
  "overrides": {
    "@sanity/astro": {
      "astro": "$astro"
    }
  }
}
