  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.1",
    "@sanity/astro": "3.2.11",
    "@sanity/client": "7.17.0",
    "@sanity/vision": "5.14.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "astro": "^6.0.8",
    "astro-portabletext": "0.13.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "lightgallery": "^2.9.0-beta.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-is": "^19.1.0",
    "sanity": "5.14.1",
    "styled-components": "6.3.11",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
