{
  "name": "portfolioAstro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "lint:css": "stylelint \"src/**/*.css\" \"src/**/*.scss\" \"**/*.astro\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" \"src/**/*.scss\" \"**/*.astro\" --fix"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.2",
    "@sanity/astro": "3.2.11",
    "@sanity/client": "7.17.0",
    "@sanity/vision": "5.14.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "astro": "^6.1.3",
    "astro-portabletext": "0.13.0",
    "lightgallery": "^2.9.0-beta.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-is": "^19.1.0",
    "sanity": "5.14.1",
    "styled-components": "6.3.11",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss-html": "^1.7.0",
    "sass-embedded": "^1.98.0",
    "stylelint": "^16.9.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-scss": "^7.0.0"
  },
  "overrides": {
    "@sanity/astro": {
      "astro": "$astro"
    }
  }
}
